# Google Gemini (AI classifier)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Telegram
TG_API_ID=123456
TG_API_HASH=your_api_hash_here
TELEGRAM_SESSION=lead_parser_session

TG_SEARCH_DELAY_MIN=30
TG_SEARCH_DELAY_MAX=60
TG_JOIN_DELAY_MIN=90
TG_JOIN_DELAY_MAX=240
TG_JOIN_DAILY_MAX=5
TG_DISCOVERY_INTERVAL_SECONDS=21600

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=WebDevScoutBot/1.0 by /u/yourusername

# VK API
VK_API_TOKEN=

# Playwright parsers
XHS_ENABLED=true
BOARDS_ENABLED=true
NAVER_ENABLED=true
BEHANCE_ENABLED=true
GOOGLE_RADAR_ENABLED=true

# Habr Career (Freelance закрыт; RSS отдаёт 410)
HABR_ENABLED=true
HABR_CAREER_URL=https://career.habr.com/vacancies?type=all
HABR_TRY_RSS=false

# Behance Jobs
BEHANCE_JOBLIST_URL=https://www.behance.net/joblist
BEHANCE_HEADLESS=true

# Уведомления о лидах (отдельный бот → ваш личный чат)
# Напишите боту /start после первого запуска
NOTIFICATION_TG_BOT_TOKEN=
NOTIFICATION_TG_CHAT_ID=

# Runtime
DB_PATH=leads.db
POLL_INTERVAL_SECONDS=300
LOG_LEVEL=INFO
