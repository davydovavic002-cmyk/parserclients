# Google Gemini (AI classifier)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Telegram
TG_API_ID=123456
TG_API_HASH=your_api_hash_here
TELEGRAM_SESSION=lead_parser_session

TG_SEARCH_DELAY_MIN=30
TG_SEARCH_DELAY_MAX=60
TG_JOIN_DELAY_MIN=90
TG_JOIN_DELAY_MAX=240
TG_JOIN_DAILY_MAX=15
TG_DISCOVERY_INTERVAL_SECONDS=21600

# Reddit — https://www.reddit.com/prefs/apps → create "script" app
# redirect uri: http://localhost:8080
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=WebDevScoutBot/1.0 by /u/YOUR_REDDIT_USERNAME

# Xiaohongshu — needs cookies from a real login (XHS blocks headless VPS)
XHS_ENABLED=true
XHS_HEADLESS=true
# After: python scripts/auth_xhs.py on PC → scp xhs_storage.json to server
XHS_STORAGE_STATE=
XHS_PAGE_DELAY=5
XHS_POLL_DELAY=8

# Playwright parsers
BOARDS_ENABLED=true
NAVER_ENABLED=true
BEHANCE_ENABLED=false
GOOGLE_RADAR_ENABLED=true

# Behance Jobs
BEHANCE_JOBLIST_URL=https://www.behance.net/joblist
BEHANCE_HEADLESS=true

# Lead notifications (separate bot → personal chat)
NOTIFICATION_TG_BOT_TOKEN=
NOTIFICATION_TG_CHAT_ID=

# Runtime
DB_PATH=leads.db
POLL_INTERVAL_SECONDS=240
LOG_LEVEL=INFO

# Lead quality (lower score = more leads)
MIN_LEAD_SCORE=50
MAX_PROPOSALS=40
MAX_POST_AGE_HOURS=72
REJECT_LOW_BUDGET=false
